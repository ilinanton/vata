# Copy to .env and fill in the values

# HuggingFace — required ONLY for the first download of Pyannote models (diarization).
# Get it: huggingface.co → Settings → Access Tokens → New token (read)
# Before that, accept the terms for two models:
#   huggingface.co/pyannote/speaker-diarization-3.1
#   huggingface.co/pyannote/segmentation-3.0
# After the first run, models are cached locally — the token is no longer used.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# OpenRouter — required ONLY if provider = "openrouter" in config.toml.
# When using Ollama (locally), this can be left empty.
# Get it: openrouter.ai → Keys → Create Key
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
