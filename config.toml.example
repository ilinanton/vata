[transcription]
# Backend: "whisperx" (CPU/CUDA via CTranslate2) or "mlx" (Apple Silicon GPU)
backend = "mlx"
# Whisper model: tiny, base, small, medium, large-v2, large-v3, large-v3-turbo
whisper_model = "large-v3-turbo"
language = "ru"               # or "auto" for auto-detection
device = "auto"               # "auto" (CUDA → CPU), "cuda", or "cpu"
compute_type = "int8"         # auto-overridden to float16 on CUDA
batch_size = 16               # parallel audio chunks for whisper (higher = faster, more RAM)
threads = 0                   # CPU threads for CTranslate2 (0 = auto)

[diarization]
min_speakers = 2
max_speakers = 6

[llm]
# Provider: "ollama" or "openrouter"
provider = "ollama"

[llm.ollama]
base_url = "http://localhost:11434"
naming_model = "llama3.2"     # model for speaker naming
analytics_model = "mistral"   # model for summary and description

[llm.openrouter]
base_url = "https://openrouter.ai/api/v1"
naming_model = "mistralai/mistral-7b-instruct"
analytics_model = "anthropic/claude-3-haiku"

[chunking]
chunk_duration = 120              # seconds per chunk
overlap_duration = 30             # seconds of overlap between chunks
speaker_similarity_threshold = 0.75  # cosine similarity threshold for speaker unification

[output]
# Directory for saving .md (default — next to the source file)
output_dir = ""
keep_audio = false            # delete temporary .wav after processing
