[transcription]
# Whisper model: tiny, base, small, medium, large-v2, large-v3
whisper_model = "large-v2"
language = "ru"               # or "auto" for auto-detection
compute_type = "int8"         # int8 for CPU, float16 for GPU

[diarization]
min_speakers = 2
max_speakers = 6

[llm]
# Provider: "ollama" or "openrouter"
provider = "ollama"

[llm.ollama]
base_url = "http://localhost:11434"
naming_model = "llama3.2"     # model for speaker naming
analytics_model = "mistral"   # model for summary and description

[llm.openrouter]
base_url = "https://openrouter.ai/api/v1"
naming_model = "mistralai/mistral-7b-instruct"
analytics_model = "anthropic/claude-3-haiku"

[output]
# Directory for saving .md (default — next to the source file)
output_dir = ""
keep_audio = false            # delete temporary .wav after processing
